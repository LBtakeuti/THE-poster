# the poster 環境変数（docs/10-env-and-deploy.md）。
# このファイルをコピーして .env.local を作り、値を埋める。
# NEXT_PUBLIC_ が付くものだけブラウザに出る。秘密鍵には絶対に付けない。
# 開発中は Stripe をテストモード（pk_test_ / sk_test_）で使う。

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 【サーバー専用】注文作成 / webhook で使用。クライアントへ出さない。
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# 【サーバー専用】Stripe 秘密鍵。
STRIPE_SECRET_KEY=
# 【サーバー専用】webhook 署名シークレット。
STRIPE_WEBHOOK_SECRET=

# --- Site ---
# 本番 URL（return_url 等に使用）。ローカルは http://localhost:3000
NEXT_PUBLIC_SITE_URL=
